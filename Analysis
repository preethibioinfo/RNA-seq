# ============================================================
# Heatmap of Top 50 Differentially Expressed Genes
# ============================================================

library(DESeq2)
library(pheatmap)
library(readr)
library(dplyr)

# Load DESeq object
load("dds_object.RData")

# Get normalized counts
vsd <- vst(dds, blind = FALSE)
norm_counts <- assay(vsd)

# Load DE results
res <- read_csv("results/DESeq2_results.csv")

# Sort by adjusted p-value
res_ordered <- res %>%
  arrange(padj)

top50_genes <- res_ordered$gene[1:50]

heatmap_data <- norm_counts[top50_genes, ]

# Scale by row
heatmap_data_scaled <- t(scale(t(heatmap_data)))

# Plot heatmap
png("figures/Heatmap_top50.png", width = 1000, height = 1000)
pheatmap(heatmap_data_scaled,
         show_rownames = TRUE,
         show_colnames = TRUE,
         clustering_distance_rows = "euclidean",
         clustering_distance_cols = "euclidean",
         clustering_method = "complete")
dev.off()
